# ============================================================================
# Aragon Media Portal — Environment Variables
# ============================================================================
# Copy this file to .env.local for local dev and fill in real values.
# NEVER commit .env.local — it's in .gitignore.
# Vercel reads these from the dashboard under Project Settings > Environment.

# --- Core ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Database (self-hosted Supabase Postgres on Oracle Cloud VM) ---
# Format: postgres://user:password@host:port/database
DATABASE_URL=""

# --- Supabase (self-hosted stack running on the VM) ---
# Only needed for the built-in file-storage + realtime features
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Auth (custom email-code) ---
# Long random string used to sign JWT session cookies. Generate with:
#   openssl rand -base64 64
AUTH_JWT_SECRET=""
# How long a session cookie stays valid (e.g., "30d", "7d")
AUTH_SESSION_TTL="30d"

# --- Credential encryption (AES-256-GCM for stored TikTok creds) ---
# 32-byte hex key. Generate with:
#   openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=""

# --- Resend (transactional email — 15-min verification codes) ---
RESEND_API_KEY=""
EMAIL_FROM="hello@kevin-aragon.com"

# --- Cloudflare R2 (file storage) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="aragon-media-files"
R2_PUBLIC_URL=""

# --- Square (activation fee payments) ---
SQUARE_ACCESS_TOKEN=""
SQUARE_LOCATION_ID=""
SQUARE_APP_ID=""
SQUARE_WEBHOOK_SIGNATURE_KEY=""
SQUARE_ENVIRONMENT="sandbox"

# --- TikTok for Developers (OAuth + GMV data) ---
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI=""
